# ══════════════════════════════════════════════════════════════════
# SnapSquad Backend — Environment Variables
# ══════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control.
# ══════════════════════════════════════════════════════════════════

# ── Database (PostgreSQL + pgvector) ─────────────────────────────
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/snapsquad

# ── Redis (for background job queue) ─────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth ─────────────────────────────────────────────────────────
# Generate real secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXP_MINUTES=120

# ── Cloudinary (encrypted photo blob storage — optional) ─────────
# Leave empty for local filesystem storage during development.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Local Storage ────────────────────────────────────────────────
DATA_DIR=backend_data
NOTEBOOKS_DIR=Notebooks
EMBEDDINGS_FILE=mobilefacenet_embeddings.json
